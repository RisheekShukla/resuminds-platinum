# ─── DATABASE ───
MONGODB_URI=mongodb+srv://<username>:<password>@cluster/resuminds

# ─── AUTHENTICATION ───
JWT_SECRET=super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# ─── CORS ───
CORS_ORIGIN=https://resuminds.vercel.app

# ─── AI PROVIDER (ZERO-COST SETUP) ───
# Options: 'groq' or 'ollama' (default)
AI_PROVIDER=groq
# Get a free key at https://console.groq.com/keys
AI_API_KEY=gsk_your_free_groq_api_key_here
# Recommended model for Groq
AI_MODEL=llama-3.3-70b-versatile
